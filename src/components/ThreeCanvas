import * as THREE from 'three';

document.addEventListener('DOMContentLoaded', () => {
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
    const renderer = new THREE.WebGLRenderer();
    renderer.setSize(window.innerWidth, window.innerHeight);
    document.body.appendChild(renderer.domElement);

    // Snake, food, and bomb properties
    const gridSize = 20;
    let snake: { x: number; y: number }[] = [{ x: 0, y: 0 }];
    let food: { x: number; y: number; mesh: THREE.Mesh | null } = { x: Math.floor(Math.random() * gridSize) - gridSize / 2, y: Math.floor(Math.random() * gridSize) - gridSize / 2, mesh: null };
    let bomb: { x: number; y: number; mesh: THREE.Mesh | null } = { x: Math.floor(Math.random() * gridSize) - gridSize / 2, y: Math.floor(Math.random() * gridSize) - gridSize / 2, mesh: null };
    let direction = { x: 1, y: 0 };
    let snakeMesh: THREE.Mesh[] = [];
    let score = 0;
    
    // Create materials
    const snakeMaterial = new THREE.MeshBasicMaterial({ color: 0x00ff00 });
    const foodMaterial = new THREE.MeshBasicMaterial({ color: 0xff0000 });
    const bombMaterial = new THREE.MeshBasicMaterial({ color: 0x000000 });

    function createCube(x: number, y: number, material: THREE.Material) {
        const geometry = new THREE.BoxGeometry(1, 1, 1);
        const cube = new THREE.Mesh(geometry, material);
        cube.position.set(x, y, 0);
        scene.add(cube);
        return cube;
    }

    function updateSnake() {
        snakeMesh.forEach(cube => scene.remove(cube));
        snakeMesh = snake.map(segment => createCube(segment.x, segment.y, snakeMaterial));
    }

    function updateFood() {
        if (food.mesh) scene.remove(food.mesh);
        food.mesh = createCube(food.x, food.y, foodMaterial);
    }

    function updateBomb() {
        if (bomb.mesh) scene.remove(bomb.mesh);
        bomb.mesh = createCube(bomb.x, bomb.y, bombMaterial);
    }
    
    function updateScore() {
        const scoreElement = document.getElementById('score');
        if (scoreElement) scoreElement.innerText = `Score: ${score}`;
    }
    
    function moveSnake() {
        const newHead = { x: snake[0].x + direction.x, y: snake[0].y + direction.y };
        
        // Check collision with food
        if (newHead.x === food.x && newHead.y === food.y) {
            snake.push({ x: snake[snake.length - 1].x, y: snake[snake.length - 1].y }); // Grow snake
            score++;
            food.x = Math.floor(Math.random() * gridSize) - gridSize / 2;
            food.y = Math.floor(Math.random() * gridSize) - gridSize / 2;
            updateFood();
        }
        
        // Check collision with bomb
        if (newHead.x === bomb.x && newHead.y === bomb.y) {
            if (snake.length > 1) {
                snake.pop(); // Shrink snake
                score--;
            }
            bomb.x = Math.floor(Math.random() * gridSize) - gridSize / 2;
            bomb.y = Math.floor(Math.random() * gridSize) - gridSize / 2;
            updateBomb();
        }
        
        // Check self-collision or boundary collision
        if (snake.some(segment => segment.x === newHead.x && segment.y === newHead.y) ||
            newHead.x < -gridSize / 2 || newHead.x > gridSize / 2 ||
            newHead.y < -gridSize / 2 || newHead.y > gridSize / 2) {
            alert(`Game Over! Final Score: ${score}`);
            location.reload();
        }

        snake.unshift(newHead);
        updateSnake();
        updateScore();
    }

    function handleKey(event: KeyboardEvent) {
        switch (event.key) {
            case 'ArrowUp': if (direction.y === 0) direction = { x: 0, y: 1 }; break;
            case 'ArrowDown': if (direction.y === 0) direction = { x: 0, y: -1 }; break;
            case 'ArrowLeft': if (direction.x === 0) direction = { x: -1, y: 0 }; break;
            case 'ArrowRight': if (direction.x === 0) direction = { x: 1, y: 0 }; break;
        }
    }

    document.addEventListener('keydown', handleKey);
    
    // Create score display
    const scoreElement = document.createElement('div');
    scoreElement.id = 'score';
    scoreElement.style.position = 'absolute';
    scoreElement.style.top = '10px';
    scoreElement.style.left = '10px';
    scoreElement.style.fontSize = '20px';
    scoreElement.style.color = 'white';
    document.body.appendChild(scoreElement);
    updateScore();
    
    camera.position.z = 10;
    updateFood();
    updateBomb();
    updateSnake();

    function animate() {
        requestAnimationFrame(animate);
        moveSnake();
        renderer.render(scene, camera);
    }
    
    setInterval(moveSnake, 200);
    animate();
});
