import * as THREE from 'three';

// Scene, Camera, Renderer
const scene = new THREE.Scene();
const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
camera.position.set(0, 10, 20);
camera.lookAt(0, 0, 0);

const renderer = new THREE.WebGLRenderer({ antialias: true });
renderer.setSize(window.innerWidth, window.innerHeight);
document.body.appendChild(renderer.domElement);

// Lighting
const light = new THREE.DirectionalLight(0xffffff, 1);
light.position.set(10, 10, 10).normalize();
scene.add(light);

// Game Variables
let snake: THREE.Mesh[] = []; // Snake is an array of Mesh objects
let snakeDirection = new THREE.Vector3(1, 0, 0);
let snakeSpeed = 0.5;
let score = 0;
let gameRunning = false; // Start only when arrow key is pressed

// UI Elements
const gameOverScreen = document.createElement('div');
gameOverScreen.innerHTML = `<h1>Game Over</h1><p>Score: <span id="finalScore">0</span></p><button id="restartBtn">Play Again</button>`;
gameOverScreen.style.cssText = "position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);background:#222;color:white;padding:20px;border-radius:10px;text-align:center;display:none;";
document.body.appendChild(gameOverScreen);

// Get the "Play Again" button, ensuring it isn't null
const restartBtn = document.getElementById('restartBtn');
if (restartBtn) {
  restartBtn.addEventListener('click', restartGame);
}

// Snake Head
const snakeMaterial = new THREE.MeshStandardMaterial({ color: 0x00ff00 });
const headGeometry = new THREE.SphereGeometry(0.5, 16, 16);
const snakeHead = new THREE.Mesh(headGeometry, snakeMaterial);
scene.add(snakeHead);
snake.push(snakeHead);

// Fruit & Bomb
function createRandomObject(color: number): THREE.Mesh {
    const geometry = new THREE.SphereGeometry(0.4, 16, 16);
    const material = new THREE.MeshStandardMaterial({ color });
    const object = new THREE.Mesh(geometry, material);
    object.position.set(Math.floor(Math.random() * 10) - 5, 0, Math.floor(Math.random() * 10) - 5);
    scene.add(object);
    return object;
}

let fruit = createRandomObject(0xff0000);
let bomb = createRandomObject(0x000000);

// Update Snake Movement
function updateSnake(): void {
    if (!gameRunning) return;

    // Move Forward
    let newHeadPosition = snake[0].position.clone().add(snakeDirection.clone().multiplyScalar(snakeSpeed));

    // Collision Check: Fruit
    if (newHeadPosition.distanceTo(fruit.position) < 0.6) {
        scene.remove(fruit);
        fruit = createRandomObject(0xff0000);
        growSnake();
        animateMouth(true);
        score++;
    }

    // Collision Check: Bomb
    if (newHeadPosition.distanceTo(bomb.position) < 0.6) {
        scene.remove(bomb);
        bomb = createRandomObject(0x000000);
        shrinkSnake();
        animateMouth(false);
        score--;
    }

    // Collision Check: Self
    for (let i = 1; i < snake.length; i++) {
        if (newHeadPosition.distanceTo(snake[i].position) < 0.5) {
            gameOver();
            return;
        }
    }

    // Collision Check: Borders (out of 10x10 range)
    if (Math.abs(newHeadPosition.x) > 10 || Math.abs(newHeadPosition.z) > 10) {
        gameOver();
        return;
    }

    // Move Snake Segments
    for (let i = snake.length - 1; i > 0; i--) {
        snake[i].position.copy(snake[i - 1].position);
    }
    snake[0].position.copy(newHeadPosition);
}

// Grow the Snake
function growSnake(): void {
    const segment = new THREE.Mesh(new THREE.BoxGeometry(0.5, 0.5, 0.5), snakeMaterial);
    scene.add(segment);
    
    let lastSegment = snake[snake.length - 1];
    segment.position.copy(lastSegment.position.clone().sub(snakeDirection.clone().multiplyScalar(0.5)));
    
    snake.push(segment);
}

// Shrink the Snake
function shrinkSnake(): void {
    if (snake.length > 1) {
        scene.remove(snake.pop() as THREE.Mesh);
    }
}

// Animate Mouth
function animateMouth(open: boolean): void {
    let scale = open ? 1.2 : 1;
    snake[0].scale.set(scale, scale, scale);
    setTimeout(() => snake[0].scale.set(1, 1, 1), 200);
}

// Game Over Logic
function gameOver(): void {
    gameRunning = false;
    document.getElementById("finalScore")!.innerText = score.toString();
    gameOverScreen.style.display = "block";
}

// Restart the Game
function restartGame(): void {
    // Remove old snake parts
    for (let i = 1; i < snake.length; i++) {
        scene.remove(snake[i]);
    }
    snake = [snakeHead]; // Reset to just the head
    snakeHead.position.set(0, 0, 0);
    snakeDirection.set(1, 0, 0);
    score = 0;
    gameOverScreen.style.display = "none";
    gameRunning = true; // Start game on first move
}

// Game Loop
function gameLoop(): void {
    if (gameRunning) updateSnake();
    renderer.render(scene, camera);
}
setInterval(gameLoop, 200);

// Start Game on First Key Press
window.addEventListener('keydown', (event) => {
    if (!gameRunning) {
        gameRunning = true; // Start game on first move
        gameOverScreen.style.display = "none"; // Hide Game Over screen
    }
    switch (event.key) {
        case 'ArrowUp': if (snakeDirection.z !== 1) snakeDirection.set(0, 0, -1); break;
        case 'ArrowDown': if (snakeDirection.z !== -1) snakeDirection.set(0, 0, 1); break;
        case 'ArrowLeft': if (snakeDirection.x !== 1) snakeDirection.set(-1, 0, 0); break;
        case 'ArrowRight': if (snakeDirection.x !== -1) snakeDirection.set(1, 0, 0); break;
    }
});
